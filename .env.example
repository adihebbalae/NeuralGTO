# NeuralGTO — Environment Variables
# Copy this file to .env and fill in your values.
# Your .env is gitignored and will never be committed.

# Google Gemini API key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# LLM Provider: "gemini" (default) or "local" (Ollama / compatible endpoint)
# LLM_PROVIDER=gemini

# Local LLM settings (used when LLM_PROVIDER=local)
# Install Ollama: https://ollama.com  then: ollama pull qwen2.5:14b
# LOCAL_LLM_ENDPOINT=http://localhost:11434/api/generate
# LOCAL_LLM_MODEL=qwen2.5:14b
